{
  "app": "npx ts-node bin/main.ts",
  "watch": {
    "include": [
      "**"
    ],
    "exclude": [
      "README.md",
      "cdk.context.json",
      "**/package-lock.json",
      "**/package.json",
      "**/node_modules/**"
    ]
  },
  "context": {
    "@aws-cdk/core:checkSecretUsage": true,
    "@aws-cdk/core:stackRelativeExports": true,
    "aws-cdk:enableDiffNoFail": true
  }
}
